// Merge this with `xcodebuild -xcconfig Build.SideStoreBundleID.xcconfig` (see get-ipa-sidestore-bundle.yml).
// Exact bundle ID match for replacing an existing SideStore-style install (team suffix included).
// Does not include Build.xcconfig — the target already loads it; these keys override the Flux defaults.

PRODUCT_BUNDLE_IDENTIFIER[config=Debug] = com.SideStore.SideStore.S32Z3HMYVQ
PRODUCT_BUNDLE_IDENTIFIER[config=Release] = com.SideStore.SideStore.S32Z3HMYVQ

GROUP_ID = com.SideStore.SideStore.S32Z3HMYVQ
GROUP_ID[config=Debug] = com.SideStore.SideStore.S32Z3HMYVQ
